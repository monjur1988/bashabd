{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "bashabd.app" }],
      "destination": "https://www.bashabd.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/blog/:path*", "destination": "/blog/:path*" },
    { "source": "/((?!blog).*)", "destination": "/index.html" }
  ]
}
